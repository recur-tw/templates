# Recur API keys — get them at app.recur.tw → Settings → Developers
# Use pk_test_/sk_test_ keys for sandbox, pk_live_/sk_live_ for production.
NEXT_PUBLIC_RECUR_PUBLISHABLE_KEY=pk_test_xxx
RECUR_SECRET_KEY=sk_test_xxx

# Webhook secret — get it at app.recur.tw → Settings → Webhooks after adding
# an endpoint pointing to https://<your-domain>/api/webhooks/recur
RECUR_WEBHOOK_SECRET=whsec_xxx

# Optional: secret used to sign the demo session cookie.
# REQUIRED in production. Generate one with: openssl rand -hex 32
AUTH_SECRET=
